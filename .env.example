# ============================================================================
# SmartLoan — example environment file
# Copy to .env and fill in real values:   cp .env.example .env
# .env itself is gitignored and must never be committed.
# Every key below maps to a field in src/smartLoan/config/settings.py.
# ============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SmartLoan
APP_VERSION=1.0.0
DEBUG=False
ENV=local                       # local | development | staging | production

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=False

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow/mlflow.db
MLFLOW_EXPERIMENT_NAME=SmartLoan_UCI_CreditDefault
MLFLOW_MODEL_NAME=SmartLoan_BestModel

# ── Kaggle (needed only to run data ingestion / download the dataset) ─────────
# Get these from https://www.kaggle.com → Account → Create New API Token
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET=uciml/default-of-credit-card-clients-dataset

# ── Paths (relative to project root locally, /app in Docker) ──────────────────
ARTIFACTS_DIR=artifacts
RAW_DATA_DIR=artifacts/raw
PROCESSED_DATA_DIR=artifacts/processed
MODEL_DIR=artifacts/models
EVALUATION_DIR=artifacts/evaluation
LOGS_DIR=logs

# ── Model / training ──────────────────────────────────────────────────────────
MODEL_NAME=best_model
MIN_PRECISION_THRESHOLD=0.40
SMOTE_OVER_RATIO=0.3
SMOTE_UNDER_RATIO=0.5
CV_FOLDS=5
RANDOM_STATE=42

# Composite-score weights (must sum to 1.0)
WEIGHT_F2=0.40
WEIGHT_PR_AUC=0.25
WEIGHT_CV_AUC=0.20
WEIGHT_ROC_AUC=0.15

# ── CORS ──────────────────────────────────────────────────────────────────────
# "*" for local dev, or a comma-separated list of allowed origins in prod.
CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/running_logs.log
